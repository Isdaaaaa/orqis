{
  "name": "@orqis/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @orqis/core build",
    "pretypecheck": "pnpm --filter @orqis/core build",
    "sqlite:doctor": "node ./scripts/sqlite-doctor.mjs",
    "sqlite:bootstrap": "node ./scripts/sqlite-bootstrap.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@orqis/core": "workspace:*",
    "better-sqlite3": "^12.6.2"
  }
}

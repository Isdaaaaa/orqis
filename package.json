{
  "name": "orqis",
  "version": "0.0.0",
  "private": true,
  "description": "Orqis monorepo workspace",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "orqis:web:sqlite:bootstrap": "pnpm --filter @orqis/web run sqlite:bootstrap",
    "orqis:web:sqlite:doctor": "pnpm --filter @orqis/web run sqlite:doctor",
    "orqis:init": "node apps/cli/dist/cli.js init",
    "smoke:workspace": "pnpm -r test",
    "smoke:filtered": "pnpm --filter @orqis/cli test && pnpm --filter @orqis/cli typecheck",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
